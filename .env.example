# Convex: run `npx convex dev` once to provision a dev deployment and fill these automatically
# Dashboard: https://dashboard.convex.dev/t/jude-okun/bwend
#
# If the site uses production URLs but waitlist fails with "Could not find public function",
# push functions to prod: `npm run deploy:convex:prod` (uses CONVEX_DEPLOYMENT from `.env.production`).
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Production deployment id (for CLI / CI): prod:helpful-owl-232
# Public URLs for prod are set in `.env.production` (Vite uses them on `vite build`).
# The string after "|" in dashboard deploy tokens is a SECRET. Never commit it; use GitHub/Vercel secrets for CI deploys.
#
# Vercel: connect this repo in the Vercel dashboard (Framework: Vite). Production URLs are in `.env.production`
# (Vite inlines them at build time). Override `VITE_CONVEX_URL` in Vercel → Project → Settings → Environment Variables if needed.

# Spotify OAuth Configuration
# Get your Client ID from: https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Redirect URI (must match what's registered in Spotify Dashboard)
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173
