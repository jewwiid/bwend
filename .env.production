# Production Convex deployment: helpful-owl-232 (prod), eu-west-1
# Safe to commit: these URLs are exposed to the browser at runtime.
# Used by `npm run deploy:convex:prod` so `convex deploy` targets prod (not dev).
CONVEX_DEPLOYMENT=prod:helpful-owl-232
VITE_CONVEX_URL=https://helpful-owl-232.eu-west-1.convex.cloud
VITE_CONVEX_SITE_URL=https://helpful-owl-232.eu-west-1.convex.site
